    <!-- ================================================================
    JAVASCRIPT
    ================================================================ -->
    <script>
        (function() {
            'use strict';

            // ============================================================
            // МОДАЛКИ
            // ============================================================

            const modalDelux = document.getElementById('modalDelux');
            const modalDonate = document.getElementById('modalDonate');
            const btnDelux = document.getElementById('btnDelux');
            const btnDonate = document.getElementById('btnDonate');
            const closeDelux = document.getElementById('closeDelux');
            const closeDonate = document.getElementById('closeDonate');

            function openModal(modal) {
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
                if (navigator.vibrate) navigator.vibrate(6);
            }

            function closeModal(modal) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }

            btnDelux.addEventListener('click', () => openModal(modalDelux));
            btnDonate.addEventListener('click', () => openModal(modalDonate));
            closeDelux.addEventListener('click', () => closeModal(modalDelux));
            closeDonate.addEventListener('click', () => closeModal(modalDonate));

            document.querySelectorAll('.modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function(e) {
                    if (e.target === this) closeModal(this);
                });
            });

            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    document.querySelectorAll('.modal-overlay.active').forEach(m => closeModal(m));
                }
            });

            // ============================================================
            // ЭФФЕКТ НА КНОПКАХ
            // ============================================================

            document.querySelectorAll('.btn').forEach(btn => {
                btn.addEventListener('mousemove', function(e) {
                    const rect = this.getBoundingClientRect();
                    const x = ((e.clientX - rect.left) / rect.width) * 100;
                    const y = ((e.clientY - rect.top) / rect.height) * 100;
                    this.style.setProperty('--mx', x + '%');
                    this.style.setProperty('--my', y + '%');
                });
            });

            // ============================================================
            // КОНФЕТТИ
            // ============================================================

            function createLiquidConfetti(modal) {
                const colors = ['rgba(255,215,0,0.2)', 'rgba(255,100,100,0.15)', 
                               'rgba(0,242,254,0.15)', 'rgba(0,255,136,0.12)',
                               'rgba(255,255,255,0.08)'];
                const container = modal.querySelector('.modal-window');
                for (let i = 0; i < 16; i++) {
                    const dot = document.createElement('div');
                    const size = 3 + Math.random() * 6;
                    const color = colors[Math.floor(Math.random() * colors.length)];
                    dot.style.cssText = `
                                position: absolute;
                                width: ${size}px;
                                height: ${size}px;
                                background: ${color};
                                border-radius: 50%;
                                pointer-events: none;
                                left: ${5 + Math.random() * 90}%;
                                top: ${5 + Math.random() * 90}%;
                                opacity: 0.7;
                                animation: liquidConfetti ${1.5 + Math.random() * 2.5}s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
                                z-index: 10;
                                backdrop-filter: blur(2px);
                                border: 0.3px solid rgba(255,255,255,0.03);
                            `;
                    container.appendChild(dot);
                    setTimeout(() => dot.remove(), 4000);
                }
            }

            const styleSheet = document.createElement('style');
            styleSheet.textContent = `
                        @keyframes liquidConfetti {
                            0% { 
                                transform: translateY(0) scale(1) rotate(0deg); 
                                opacity: 0.7;
                            }
                            100% { 
                                transform: translateY(${60 + Math.random() * 80}px) scale(0) rotate(${360 + Math.random() * 360}deg); 
                                opacity: 0;
                            }
                        }
                    `;
